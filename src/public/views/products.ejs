<%- include('./partials/header') %>

<style>
    body { background-color: #0b0b0b; color: #f8f9fa; font-family: 'Inter', sans-serif; }
    .product-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 15px;
    }
    .img-preview { width: 100%; aspect-ratio: 1/1; object-fit: cover; border-radius: 10px; margin-bottom: 10px; opacity: 0.7; }
    .modal-content { background: #121212; border: 1px solid #333; color: white; border-radius: 20px; }
    .form-control { background: #1a1a1a !important; border: 1px solid #333 !important; color: white !important; }
    .divider { border-top: 1px solid #333; margin: 20px 0; }
</style>

<div class="container py-5">
    <div class="row g-4">
        <% productsData.forEach(product => { %>
            <div class="col-md-3">
                <div class="product-card p-3 text-center">
                    <img src="/uploads/<%= product.image %>" class="img-preview" alt="foto">
                    <h6 class="fw-bold"><%= product.name %></h6>
                    <p class="text-warning small">R$ <%= product.price %></p>
                    
                    <button class="btn btn-sm btn-warning w-100 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#modal<%= product.id %>">
                        GERENCIAR
                    </button>
                </div>
            </div>

            <div class="modal fade" id="modal<%= product.id %>" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-sm">
                    <div class="modal-content p-3">
                        
                        <form action="/admin/editproduct" method="POST">
                            <div class="modal-body pb-0">
                                <h6 class="text-warning fw-bold mb-3 small text-uppercase">Dados do Produto</h6>
                                <input type="hidden" name="productId" value="<%= product.id %>">
                                
                                <div class="mb-2">
                                    <label class="small opacity-50">NOME</label>
                                    <input type="text" name="productName" value="<%= product.name %>" class="form-control form-control-sm" required>
                                </div>

                                <div class="mb-2">
                                    <label class="small opacity-50">PREÇO</label>
                                    <input type="number" step="0.01" name="productPrice" value="<%= product.price %>" class="form-control form-control-sm" required>
                                </div>

                                <div class="mb-3">
                                    <label class="small opacity-50">ESTOQUE ATUAL</label>
                                    <input type="number" name="productStock" value="<%= product.stock %>" class="form-control form-control-sm" required>
                                </div>

                                <button type="submit" class="btn btn-outline-warning w-100 btn-sm fw-bold">SALVAR DADOS</button>
                            </div>
                        </form>

                        <div class="divider"></div>

                        <form action="/admin/newkey" method="POST">
                            <div class="modal-body pt-0">
                                <h6 class="text-info fw-bold mb-3 small text-uppercase">Abastecer Estoque (Key)</h6>
                                
                                <input type="hidden" name="productId" value="<%= product.id %>">
                                
                                <div class="mb-3">
                                    <label class="small opacity-50">CÓDIGO DA KEY</label>
                                    <input type="text" name="keyCode" placeholder="Ex: ABCD-1234" class="form-control form-control-sm" required>
                                </div>

                                <button type="submit" class="btn btn-info w-100 btn-sm fw-bold text-dark">ADICIONAR KEY</button>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<%- include('./partials/footer') %>