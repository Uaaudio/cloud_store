<%- include("./partials/header.ejs") %>

<style>
    /* --- PADRÃO VISUAL CLOUD STORE --- */
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    body {
        animation: fadeIn 0.8s ease-out;
        background-color: #000;
        font-family: 'Inter', sans-serif;
        color: #f8f9fa;
        overflow-x: hidden;
    }

    /* --- BACKGROUND VIDEO --- */
    #bg-video {
        position: fixed;
        right: 0; bottom: 0;
        min-width: 100%; min-height: 100%;
        z-index: -1000;
        object-fit: cover;
        filter: blur(10px) brightness(0.4); 
        transform: scale(1.1);
    }

    .overlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.4);
        z-index: -999;
    }

    /* --- CARDS DE PRODUTO --- */
    .product-card {
        background: rgba(20, 20, 20, 0.6) !important;
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .product-card:hover {
        transform: translateY(-12px);
        border-color: rgba(255, 255, 255, 0.2);
        box-shadow: 0 15px 35px rgba(0,0,0,0.6) !important;
    }

    .img-wrapper {
        height: 180px;
        overflow: hidden;
        border-radius: 15px;
        background: rgba(255,255,255,0.02);
    }

    .img-wrapper img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .product-card:hover .img-wrapper img { transform: scale(1.1); }

    .price-tag { color: #fff; font-weight: 700; font-size: 1.1rem; }

    .btn-buy { 
        background-color: #fff; color: #000; 
        border: none; font-weight: 600; font-size: 0.8rem;
        border-radius: 10px; padding: 8px 18px;
        transition: 0.3s;
    }

    .btn-buy:hover { background-color: #0dcaf0; color: #fff; }

    .content-section { margin-top: 120px; margin-bottom: 80px; }
</style>

<video autoplay muted loop id="bg-video">
    <source src="/videos/background.mp4" type="video/mp4">
</video>
<div class="overlay"></div>

<nav class="navbar navbar-expand-lg navbar-dark fixed-top" style="background: rgba(10,10,10,0.8); backdrop-filter: blur(15px);">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">CLOUD STORE</a>
        <div class="ms-auto">
            <a href="/categories" class="btn btn-sm btn-outline-light px-3" style="border-radius: 20px;">Voltar Categorias</a>
        </div>
    </div>
</nav>

<div class="container content-section">
    
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h2 class="fw-bold display-6 mb-2">PRODUTOS ENCONTRADOS</h2>
            <p class="text-white-50">Explore os itens disponíveis nesta categoria.</p>
        </div>
    </div>

    <div class="row g-4">
        <% if (productsData && productsData.length > 0) { %>
            <% productsData.forEach(product => { %>
                <div class="col-md-6 col-lg-3">
                    <div class="card product-card h-100 shadow-sm p-3">
                        <div class="img-wrapper mb-3">
                            <img src="/uploads/<%= product.image %>" alt="<%= product.name %>">
                        </div>
                        
                        <div class="card-body d-flex flex-column p-0">
                            <h6 class="text-white fw-bold mb-3"><%= product.name %></h6>
                            
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <span class="price-tag">R$ <%= product.price %></span>
                                
                                <form action="/order/checkout" method="POST">
                                    <input type="hidden" name="productId" value="<%= product.id %>">
                                    <button type="submit" class="btn-buy" <%= product.stock <= 0 ? 'disabled' : '' %>>
                                        <%= product.stock <= 0 ? 'Esgotado' : 'Comprar' %>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center py-5">
                <h5 class="text-white-50">Ops! Nenhum produto encontrado nesta categoria.</h5>
                <a href="/categories" class="btn btn-link text-info text-decoration-none mt-3">Ver outras categorias</a>
            </div>
        <% } %>
    </div>

</div>

<script>
    window.addEventListener('load', () => {
        const video = document.getElementById('bg-video');
        if (video) video.playbackRate = 0.5;
    });
</script>

<%- include("./partials/footer.ejs") %>