<%- include("./partials/header.ejs") %>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<style>
    /* --- ESTILOS GERAIS --- */
    @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    body { animation: fadeIn 0.8s ease-out; background-color: #000; font-family: 'Inter', sans-serif; color: #f8f9fa; overflow-x: hidden; }
    #bg-video { position: fixed; right: 0; bottom: 0; min-width: 100%; min-height: 100%; z-index: -1000; object-fit: cover; filter: blur(10px) brightness(0.4); transform: scale(1.1); }
    .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.4); z-index: -999; }
    .navbar-cloud { background: rgba(10, 10, 10, 0.8) !important; backdrop-filter: blur(15px); border-bottom: 1px solid rgba(255, 255, 255, 0.05); padding: 15px 0; }
    .nav-link-clean { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 500; color: rgba(255, 255, 255, 0.7) !important; transition: 0.3s; }
    .nav-link-clean:hover, .nav-link-clean.active { color: #fff !important; }
    .login-btn-minimal { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 400; color: rgba(255, 255, 255, 0.5) !important; border: 1px solid rgba(255, 255, 255, 0.15); padding: 6px 18px !important; border-radius: 30px; transition: all 0.4s ease; margin-left: 20px; }
    .login-btn-minimal:hover { color: #fff !important; border-color: #fff; background: rgba(255, 255, 255, 0.05); }

    /* --- CARDS DE PRODUTO --- */
    .content-section { margin-top: 120px; margin-bottom: 80px; }
    .product-card { background: rgba(20, 20, 20, 0.6) !important; backdrop-filter: blur(8px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 20px; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .product-card:hover { transform: translateY(-12px); border-color: rgba(255, 255, 255, 0.2); box-shadow: 0 15px 35px rgba(0,0,0,0.6) !important; }
    .img-wrapper { height: 200px; overflow: hidden; border-radius: 15px; background: rgba(255,255,255,0.02); }
    .img-wrapper img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
    .product-card:hover .img-wrapper img { transform: scale(1.1); }
    .product-price { color: #fff; font-weight: 700; font-size: 1.1rem; }
    .btn-buy { background-color: #fff; color: #000; border: none; font-weight: 600; font-size: 0.8rem; border-radius: 10px; padding: 8px 18px; transition: 0.3s; }
    .btn-buy:hover { background-color: #0dcaf0; color: #fff; }

    /* --- ESTILOS DO CARRINHO --- */
    .cart-float { position: fixed; bottom: 30px; right: 30px; z-index: 1001; background: #fff; color: #000; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 10px 30px rgba(0,0,0,0.5); transition: 0.3s; }
    .cart-float:hover { transform: scale(1.1); }
    .cart-count { position: absolute; top: 0; right: 0; background: #ffc107; color: #000; width: 22px; height: 22px; border-radius: 50%; font-size: 0.7rem; font-weight: 800; display: flex; align-items: center; justify-content: center; border: 2px solid #000; }
    .offcanvas { background: rgba(10, 10, 10, 0.95) !important; backdrop-filter: blur(20px); color: #fff; border-left: 1px solid rgba(255,255,255,0.1); }
    .cart-item { background: rgba(255,255,255,0.05); border-radius: 15px; padding: 15px; margin-bottom: 10px; display: flex; align-items: center; gap: 15px; }
    .cart-item img { width: 50px; height: 50px; object-fit: cover; border-radius: 10px; }
</style>

<video autoplay muted loop id="bg-video"><source src="/videos/background.mp4" type="video/mp4"></video>
<div class="overlay"></div>

<nav class="navbar navbar-expand-lg navbar-dark navbar-cloud fixed-top">
    <div class="container">
        <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
            <img src="/imgs/cloudicon.png" alt="Logo" width="35">
            <span style="letter-spacing: 1px;">CLOUD STORE</span>
        </a>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item"><a class="nav-link nav-link-clean active" href="/">Home</a></li>
                <li class="nav-item"><a class="nav-link nav-link-clean" href="/categories">Categorias</a></li>
                <li class="nav-item"><a class="nav-link login-btn-minimal" href="/login">Entrar</a></li>
            </ul>
        </div>
    </div>
</nav>

<div class="cart-float" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas">
    <i class="bi bi-cart3 fs-4"></i>
    <span class="cart-count" id="cartCount">0</span>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="cartOffcanvas">
    <div class="offcanvas-header border-bottom border-secondary">
        <h5 class="offcanvas-title fw-bold">MEU CARRINHO</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <div id="cartItemsList">
            </div>
        
        <div class="mt-4 border-top border-secondary pt-3">
            <div class="d-flex justify-content-between mb-3">
                <span class="opacity-50 text-uppercase small">Total</span>
                <span class="fw-bold fs-5" id="cartTotal">R$ 0,00</span>
            </div>
            <button class="btn btn-warning w-100 fw-bold py-3" onclick="checkout()">FINALIZAR COMPRA</button>
        </div>
    </div>
</div>

<div class="container content-section">
    <div class="row mb-5 text-center">
        <div class="col-12">
            <h2 class="fw-bold display-5 mb-2">Cloud Store</h2>
            <p class="text-white-50">Produtos selecionados com curadoria Cloud.</p>
        </div>
    </div>

    <div class="row g-4">
        <% if (typeof products !== 'undefined' && products.length > 0) { %>
            <% products.forEach(product => { %>
                <div class="col-md-6 col-lg-3">
                    <div class="card product-card h-100 shadow-sm">
                        <div class="p-3">
                            <div class="img-wrapper">
                                <img src="<%= product.image ? '/uploads/' + product.image : '/imgs/no-image.jpg' %>" alt="<%= product.name %>">
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column pt-0">
                            <h6 class="card-title fw-bold text-white mb-2"><%= product.name %></h6>
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <span class="product-price text-info">R$ <%= product.price %></span>
                                <button class="btn btn-buy" 
                                        onclick="addToCart('<%= product.id %>', '<%= product.name %>', '<%= product.price %>', '<%= product.image %>')">
                                    Adicionar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<script>
    let cart = JSON.parse(localStorage.getItem('cloud_cart')) || [];

    function addToCart(id, name, price, image) {
        cart.push({ id, name, price: parseFloat(price), image });
        updateCart();
        new bootstrap.Offcanvas(document.getElementById('cartOffcanvas')).show();
    }

    function removeFromCart(index) {
        cart.splice(index, 1);
        updateCart();
    }

    function updateCart() {
        localStorage.setItem('cloud_cart', JSON.stringify(cart));
        const list = document.getElementById('cartItemsList');
        const count = document.getElementById('cartCount');
        const totalDisp = document.getElementById('cartTotal');
        
        count.innerText = cart.length;
        list.innerHTML = '';
        let total = 0;

        cart.forEach((item, index) => {
            total += item.price;
            list.innerHTML += `
                <div class="cart-item">
                    <img src="${item.image ? '/uploads/' + item.image : '/imgs/no-image.jpg'}" alt="img">
                    <div class="flex-grow-1">
                        <h6 class="mb-0 small fw-bold text-truncate" style="max-width: 120px;">${item.name}</h6>
                        <span class="text-info small">R$ ${item.price.toFixed(2)}</span>
                    </div>
                    <button class="btn btn-sm text-danger" onclick="removeFromCart(${index})">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>`;
        });
        totalDisp.innerText = `R$ ${total.toFixed(2)}`;
    }

    // LÓGICA DE CHECKOUT COM AXIOS
    async function checkout() {
        if(cart.length === 0) return alert("Adicione algo ao carrinho primeiro!");

        try {
            const btn = document.querySelector('button[onclick="checkout()"]');
            btn.innerText = "PROCESSANDO...";
            btn.disabled = true;

            // Envia o carrinho para a sua rota /checkout no Node.js
            const response = await axios.post('/checkout', { 
                items: cart,
                customerEmail: 'cliente@exemplo.com' 
            });

            if (response.data && response.data.url) {
                localStorage.removeItem('cloud_cart');
                window.location.href = response.data.url; // Vai para o PagBank
            }
        } catch (error) {
            console.error("Erro no checkout:", error);
            alert("Erro ao conectar com o servidor. Verifique o console ou o Token!");
            
            const btn = document.querySelector('button[onclick="checkout()"]');
            btn.innerText = "FINALIZAR COMPRA";
            btn.disabled = false;
        }
    }

    window.addEventListener('load', () => {
        updateCart();
        const video = document.getElementById('bg-video');
        if (video) video.playbackRate = 0.5;
    });
</script>

<%- include("./partials/footer.ejs") %>