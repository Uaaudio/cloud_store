<%- include('./partials/header') %>

<style>
    body { background-color: #0b0b0b; color: #f8f9fa; font-family: 'Inter', sans-serif; }
    .dashboard-wrapper { padding-top: 4vh; }

    .category-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        transition: 0.3s;
    }

    .category-card:hover {
        transform: translateY(-5px);
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.3);
    }

    .id-badge {
        font-size: 0.65rem;
        background: rgba(255, 255, 255, 0.05);
        padding: 4px 8px;
        border-radius: 6px;
        color: #666;
    }

    .btn-view {
        border: 1px solid #0dcaf0;
        color: #0dcaf0;
        border-radius: 10px;
        font-size: 0.75rem;
        font-weight: 700;
        text-decoration: none;
    }

    .btn-view:hover { background: #0dcaf0; color: #000; }

    .btn-edit-cat {
        font-size: 0.75rem;
        color: #ffc107;
        text-decoration: none;
        font-weight: 600;
    }

    .modal-content {
        background: rgba(15, 15, 15, 0.98);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        color: white;
    }
    
    .form-control {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: white !important;
        border-radius: 12px;
    }
</style>

<nav class="navbar border-bottom border-secondary mb-4 py-3">
    <div class="container">
        <span class="navbar-brand fw-bold">CLOUD <span class="text-white-50">ADMIN</span></span>
        <a href="/admin/dashboard" class="btn btn-sm btn-outline-light px-3">Painel</a>
    </div>
</nav>

<div class="container dashboard-wrapper">
    <div class="row g-4">
        <% if(categories && categories.length > 0) { %>
            <% categories.forEach(category => { %>
                <div class="col-md-6 col-lg-4">
                    <div class="category-card p-4 shadow-sm">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <span class="id-badge">#<%= category.id %></span>
                                <h4 class="m-0 mt-2 fw-bold text-white text-uppercase"><%= category.name %></h4>
                            </div>
                            
                            <a href="javascript:void(0)" class="btn-edit-cat" 
                               data-bs-toggle="modal" 
                               data-bs-target="#editCategoryModal"
                               onclick="prepareEditCategory('<%= category.id %>', '<%= category.name %>')">
                                Editar
                            </a>
                        </div>

                        <div class="d-grid mt-4">
                            <a href="/admin/category/<%= category.id %>/products" class="btn btn-view py-2 text-center">
                                Ver Produtos
                            </a>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h6 class="modal-title fw-bold text-warning text-uppercase">Renomear</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            
            <form action="/admin/editcategory" method="POST">
                <div class="modal-body">
                    <input type="hidden" name="categoryId" id="inputCatId">
                    
                    <div class="mb-3">
                        <label class="form-label small opacity-50">NOME</label>
                        <input type="text" name="categoryName" id="inputCatName" class="form-control" required>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="submit" class="btn btn-warning w-100 fw-bold text-dark">SALVAR</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function prepareEditCategory(id, name) {
        document.getElementById('inputCatId').value = id;
        document.getElementById('inputCatName').value = name;
    }
</script>

<%- include('./partials/footer') %>